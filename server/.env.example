# Azure Speech Service (STT / TTS)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# Azure OpenAI (meeting notes)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Azure Translator
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_ENDPOINT=https://<your-translator>.cognitiveservices.azure.com
AZURE_TRANSLATOR_REGION=eastus

# Azure Content Safety
AZURE_CONTENT_SAFETY_ENDPOINT=https://<your-safety>.cognitiveservices.azure.com
AZURE_CONTENT_SAFETY_KEY=

# Azure Cosmos DB
AZURE_COSMOS_ENDPOINT=https://<your-cosmos>.documents.azure.com:443/
AZURE_COSMOS_KEY=

# Azure Communication Services
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://<your-acs>.communication.azure.com/;accesskey=...

# Azure Monitor / Application Insights
AZURE_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# Azure Blob Storage (meeting recordings, PDFs, sign clips)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<your-storage>;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_ACCOUNT_NAME=<your-storage>
AZURE_STORAGE_ACCOUNT_KEY=

# Azure Key Vault (optional — loads all above keys from Key Vault at startup)
AZURE_KEYVAULT_URL=https://<your-vault>.vault.azure.net/

# Azure Functions (serverless meeting summary, alerts)
AZURE_FUNCTIONS_URL=https://<your-functions>.azurewebsites.net

# Azure SignalR Service (real-time bidirectional messaging)
AZURE_SIGNALR_CONNECTION_STRING=Endpoint=https://<your-signalr>.service.signalr.net;AccessKey=...;Version=1.0;

# Azure AI Language (PII detection, sentiment analysis)
AZURE_LANGUAGE_ENDPOINT=https://<your-language>.cognitiveservices.azure.com
AZURE_LANGUAGE_KEY=

# GPU VM (Uni-Sign sign language recognition)
GPU_VM_URL=http://<your-gpu-vm-ip>:8000
